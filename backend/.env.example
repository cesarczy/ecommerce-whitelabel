# Backend environment variables (copy to .env)

# App
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://ecommerce:ecommerce@localhost:5432/ecommerce

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ / Celery
CELERY_BROKER_URL=amqp://ecommerce:ecommerce@localhost:5672//
USE_CELERY_EVENTS=false

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=products
MINIO_SECURE=false

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:4200

# Payments (Fase 2)
MERCADO_PAGO_ACCESS_TOKEN=
STRIPE_SECRET_KEY=

# OAuth2 (Fase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/callback
